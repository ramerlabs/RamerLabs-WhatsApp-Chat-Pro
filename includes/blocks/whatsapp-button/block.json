{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ramerlabs/whatsapp-chat-button",
	"title": "WhatsApp Chat Button",
	"category": "widgets",
	"icon": "whatsapp",
	"description": "Inline WhatsApp chat button with smart routing and GDPR consent.",
	"keywords": ["whatsapp", "chat", "support", "sales"],
	"textdomain": "ramerlabs-whatsapp-chat-pro",
	"attributes": {
		"buttonText": {
			"type": "string",
			"default": ""
		},
		"department": {
			"type": "string",
			"default": ""
		},
		"style": {
			"type": "string",
			"default": "button"
		},
		"showIcon": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"align": ["left", "center", "right"]
	},
	"editorScript": "file:./editor.js"
}
